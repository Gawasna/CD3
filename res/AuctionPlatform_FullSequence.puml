@startuml
!theme plain
autonumber
skinparam style strictuml
skinparam MaxMessageSize 200

title Siêu Sơ Đồ Trình Tự Toàn Vòng Đời Đấu Giá (AuctionPlatform)

actor "Seller (Người bán)" as Seller #LightGreen
actor "Bidder 1 (Người thầu)" as B1 #LightBlue
actor "Bidder 2 (Người thầu mới)" as B2 #LightCyan
actor "Admin/Phân xử" as Admin #LightCoral

participant "AuctionPlatform.sol" as Contract << (C,#ADD1B2) >>

== 1. Khởi Tạo & Đấu Giá ==

Seller -> Contract: createAuction(startingPrice, duration, collateral) + ETH Collateral
activate Contract
Contract --> Seller: Emit AuctionCreated(id)
deactivate Contract

B1 -> Contract: bid(id) + ETH Bid
activate Contract
Contract --> B1: Emit BidPlaced(id, B1, bidAmount)
deactivate Contract

... Trong thời gian đấu giá ...

B2 -> Contract: bid(id) + ETH Higher Bid
activate Contract
    Contract -> Contract: Check Anti-sniping (Extends time if needed)
    group Push-Pull Fallback (Hoàn tiền thầu cũ)
        Contract -> B1: call{value: prevBid} (Push)
        alt Push Failed
            Contract -> Contract: pendingReturns[B1] += prevBid (Pull)
        end
    end
Contract --> B2: Emit BidPlaced(id, B2, higherBid)
deactivate Contract

B1 -> Contract: withdraw() (If Push failed)
activate Contract
Contract -> B1: Transfer pending funds
deactivate Contract

== 2. Kết Thúc & Ký Quỹ (Escrow) ==

... Hết thời gian đấu giá ...

B2 -> Contract: endAuction(id)
activate Contract
Contract -> Contract: status = Ended, escrow = AwaitingShipment
Contract --> B2: Emit AuctionEnded(id, winner, amount)
deactivate Contract

Admin -> Contract: setShippingFee(id, fee)
activate Contract
deactivate Contract

B2 -> Contract: payShippingFee(id) + ETH
activate Contract
deactivate Contract

Seller -> Contract: markShipped(id, proofHash)
activate Contract
Contract -> Contract: deliveryDeadline = now + 7 days
Contract --> Seller: Emit ItemShipped(id)
deactivate Contract

== 3. Các Nhánh Kết Thúc (Kịch Bản Khác Nhau) ==

alt Kịch bản A: Giao dịch thành công
    B2 -> Contract: confirmDelivery(id)
    activate Contract
    Contract -> Contract: status = Completed
    Contract -> Seller: Transfer (Bid + Collateral - PlatformFee - ShipFee)
    Contract -> Contract: adminFeeBalance += PlatformFee + ShipFee
    deactivate Contract

else Kịch bản B: Người mua "quên" xác nhận (Auto-release)
    ... Sau 7 ngày (deliveryDeadline) ...
    Seller -> Contract: claimFunds(id)
    activate Contract
    Contract -> Seller: Transfer (Bid + Collateral - Fees)
    deactivate Contract

else Kịch bản C: Tranh chấp (Dispute)
    B2 -> Contract: raiseDispute(id) + ETH Bond
    activate Contract
    Contract -> Contract: status = Disputed
    deactivate Contract
    
    Admin -> Contract: resolveDispute(id, buyerRefund%)
    activate Contract
    Contract -> B2: Refund (part of Bid + Collateral + Bond)
    Contract -> Seller: Payout (remaining part)
    deactivate Contract

else Kịch bản D: Người thắng từ bỏ (Forfeit) - Chỉ trước khi ship
    B2 -> Contract: forfeitWin(id)
    activate Contract
    Contract -> Contract: Penalty = 10% of Bid
    Contract -> Seller: Refund Collateral + 80% of Penalty
    Contract -> B2: Refund remaining 90% of Bid
    Contract -> Contract: adminFeeBalance += 20% of Penalty
    deactivate Contract
end

== 4. Quản Trị Phí ==

Admin -> Contract: withdrawAdminFee()
activate Contract
Contract -> Admin: Transfer accumulated fees
deactivate Contract

@enduml
