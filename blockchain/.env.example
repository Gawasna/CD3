# Ganache local network
# Lấy URL và Chain ID từ Ganache UI (Settings > Server)
GANACHE_URL=http://127.0.0.1:7545
GANACHE_CHAIN_ID=1337

# Private key của account đầu tiên trong Ganache (Account #0)
# Lấy từ: Ganache UI > click vào icon key bên cạnh account
# WARNING: Chỉ dùng cho local dev — KHÔNG bao giờ commit key thật
DEPLOYER_PRIVATE_KEY=0x<paste_ganache_account0_private_key_here>

# Contract address sau khi deploy (điền sau khi chạy deploy:local)
CONTRACT_ADDRESS=0x

# Sepolia (tương lai)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
ETHERSCAN_API_KEY=
