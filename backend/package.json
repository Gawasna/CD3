{
  "name": "cd3-backend",
  "version": "1.0.0",
  "description": "Backend API for CD3 Auction Platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:seed": "npx prisma db seed"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "sharp": "^0.34.5",
    "siwe": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
